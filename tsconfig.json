{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@/theme": [
        "./src/theme/index.ts"
      ],
      "@/theme/*": [
        "./src/theme/*"
      ],
      "@/tw": [
        "./src/tw/index.tsx"
      ],
      "@/tw/*": [
        "./src/tw/*"
      ],
      "@/hooks": [
        "./src/hooks/index.ts"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
